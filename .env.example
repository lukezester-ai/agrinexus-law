# AgriNexus Environment Variables

# Mistral AI API Key for the Agent Mesh (LangGraph)
# Get your API key here: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional model overrides (default: mistral-small-latest where not set)
# MISTRAL_ORCHESTRATOR_MODEL=mistral-small-latest
# MISTRAL_MARKET_AGENT_MODEL=mistral-small-latest
# MISTRAL_WEATHER_AGENT_MODEL=mistral-small-latest
# MISTRAL_CROP_AGENT_MODEL=mistral-small-latest
# MISTRAL_FIELD_AGENT_MODEL=mistral-small-latest
# MISTRAL_OPERATIONS_AGENT_MODEL=mistral-small-latest
# MISTRAL_FINANCE_AGENT_MODEL=mistral-small-latest
# MISTRAL_COMPLIANCE_AGENT_MODEL=mistral-small-latest
# MISTRAL_SUSTAINABILITY_AGENT_MODEL=mistral-small-latest
# MISTRAL_NEWS_AGENT_MODEL=mistral-small-latest
# MISTRAL_ACADEMY_AGENT_MODEL=mistral-small-latest
# MISTRAL_GENERAL_AGENT_MODEL=mistral-small-latest
# MISTRAL_ACADEMY_TUTOR_MODEL=mistral-small-latest
# MISTRAL_MESH_MODEL=mistral-small-latest

# Rate limits (requests per IP per minute)
# AGN_MESH_RATE_LIMIT_PER_MIN=40
# AGN_ACADEMY_RATE_LIMIT_PER_MIN=30

# Required by apps/web API proxy routes in production. Use the deployed root marketing/API origin.
# Local development falls back to http://127.0.0.1:3456.
# AGN_MARKETING_ORIGIN=https://your-marketing-domain.example

# Fieldlot smoke: set to 1 in CI when API is running to enforce HTTP checks
# FIELDLOT_SMOKE_STRICT=0

# Other keys if needed in the future
# OPENAI_API_KEY=
