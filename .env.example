# Копирай като `.env` в корена (или ползвай `.env.local` — има приоритет).
# Този файл се комитира; не слагай реални секрети тук.

# OpenAI API ключ - ЗАДЪЛЖИТЕЛЕН
# Получавате от https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# Модел (по подразбиране в кода: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Supabase - ЗАДЪЛЖИТЕЛНИ за waitlist и chat logs
# Получавате от https://supabase.com (безплатен план)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Публичен URL на сайта (SEO, canonical — задължително в production)
NEXT_PUBLIC_SITE_URL=https://agrinexus.bg

# Resend - за изпращане на welcome имейли (опционално, но препоръчително)
# Получавате от https://resend.com (безплатен план)
RESEND_API_KEY=re_...
# Подател с верифициран домейн в Resend (пример: AgriNexus.Law <hello@agrinexus.bg>)
# Локално може да ползвате onboarding@resend.dev без промяна на FROM в таблото.
RESEND_FROM=AgriNexus.Law <onboarding@resend.dev>

# Upstash Redis - за rate limiting (опционално, препоръчително за production)
# Получавате от https://upstash.com (безплатен план)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
# Ако ползвате Vercel KV интеграция, може и така:
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# Cloudflare Turnstile - bot защита за login magic link (препоръчително за production)
# Site key е публичен (в браузъра), secret key остава само на сървъра.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
TURNSTILE_SECRET_KEY=0x4AAAA...

# Meilisearch (по избор) - по-бърза и интелигентна търсачка
# Ако е празно, API автоматично ползва локалното searchKnowledge().
# Локално може да се пусне с Docker:
# docker run -it --rm -p 7700:7700 -e MEILI_MASTER_KEY=masterKey getmeili/meilisearch:v1.12
MEILI_HOST=http://127.0.0.1:7700
MEILI_API_KEY=masterKey
MEILI_INDEX=knowledge_docs

# Ingest admin token (за ръчно пускане на /api/ingest/run)
INGEST_ADMIN_TOKEN=change-me-ingest-token
# Ограничители за ingest download (DoS/cost guardrails)
# INGEST_MAX_FILE_BYTES=15728640
# INGEST_DOWNLOAD_TIMEOUT_MS=15000
# 1 = allow external file links от index страницата (по подразбиране е само same-origin)
# INGEST_ALLOW_EXTERNAL_LINKS=0

# Learning loop cron token (за /api/learning/cron)
LEARNING_CRON_TOKEN=change-me-learning-token

# ─── RAG (Retrieval-Augmented Generation) ─────────────────────────────
# Включва hybrid retrieval (pgvector + BM25) в /api/chat.
# Изисква supabase-rag-setup.sql да е изпълнен в Supabase + OPENAI_API_KEY + SERVICE_ROLE_KEY.
# Изключете с RAG_ENABLED=0 ако искате временно само BM25.
RAG_ENABLED=1
# Embedding модел — text-embedding-3-small е 1536 dim (по подразбиране, евтин и качествен).
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Минимум cosine similarity (0..1) за включване в контекста.
# RAG_MATCH_THRESHOLD=0.3
# Брой chunks от vector search преди rerank.
# RAG_VECTOR_TOP_K=8
# Брой документи от BM25 (lexical) преди rerank.
# RAG_LEXICAL_TOP_K=8
# Финален брой парчета в prompt контекста.
# RAG_FINAL_TOP_K=6

# ─── Content RAG (PDF/HTML/DOCX download + parse + chunk + embed) ────
# Използва се от POST /api/rag/reindex с body { target: "public_doc_content" }.
# Лимити за изтегляне на документи (PDF/HTML/DOCX):
# CONTENT_FETCH_TIMEOUT_MS=25000
# CONTENT_MAX_BYTES=15728640

# OCR fallback (само за scanned PDFs без текстов слой).
# Тежко: ~10 MB Bulgarian + English Tesseract данни на първи run +
# ~5–10s/страница. Включи при нужда.
# RAG_OCR_ENABLED=1
# RAG_OCR_LANGS=bul+eng
# RAG_OCR_MAX_PAGES=30
# RAG_OCR_MIN_TEXT_CHARS=200
# RAG_OCR_SCALE=2
