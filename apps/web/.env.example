# FastAPI (apps/backend). Сървърни заявки от Next могат да ползват API_URL; клиентски — NEXT_PUBLIC_*.
API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Next (сървърно) извиква apps/backend през API_URL за GET /auth/me при Bearer към /api/mobile/courses.
# За next.config rewrites в development (по подразбиране е същото).
# BACKEND_ORIGIN=http://127.0.0.1:8000

# Чат (dashboard/ask, /ask): POST /api/chat — директно Mistral в Next (без порт 3456).
# По избор за стар маркетинг сървър: AGN_MARKETING_ORIGIN=http://127.0.0.1:3456
# AGN_MARKETING_ORIGIN=http://127.0.0.1:3456

# /market — един кратък параграф през Mistral API (направо от Next). По желание: MISTRAL_MARKET_NOTE_MODEL=mistral-small-latest
# Supabase (apps/web login + dashboard). URL = Project URL only — NOT .../rest/v1/
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (server only — cron + Telegram webhook link)

# Monday briefing (Telegram). Create bot via @BotFather; webhook → https://YOUR_APP/api/telegram/webhook
# TELEGRAM_BOT_TOKEN=
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotName
# TELEGRAM_WEBHOOK_SECRET=random-string-for-x-telegram-bot-api-secret-token
# CRON_SECRET=random-string-vercel-sends-as-bearer-on-cron
# NEXT_PUBLIC_SITE_URL=https://agrinexus-final-real.vercel.app

# Decision diary table: apps/backend/rag/decision_diary.sql (Supabase SQL editor, once)
# AI Community feed: apps/backend/rag/community_posts.sql

# Mistral — market desk, AI Community (/community), AI perspective button
# https://console.mistral.ai/ → API keys → paste in Vercel (apps/web project) + .env.local
# MISTRAL_API_KEY=
# MISTRAL_COMMUNITY_MODEL=mistral-small-latest
# MISTRAL_MARKET_NOTE_MODEL=mistral-small-latest

# По желание: висококачествено четене на глас в /academy/lecturer през ElevenLabs (ключът е само на сървъра).
# Глас: https://elevenlabs.io/app/voice-library?voiceId=M1ydWt7KnBCiuv4CnEDC — копирай Voice ID в .env.local.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=M1ydWt7KnBCiuv4CnEDC
# По желание: ELEVENLABS_MODEL_ID=eleven_multilingual_v2
