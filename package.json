{
  "name": "agrinexus-mvp",
  "version": "1.0.0",
  "private": true,
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "node scripts/dev-next.cjs",
    "dev:3020": "next dev -p 3020",
    "build": "node scripts/verify-build-env.mjs && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "test": "npm run typecheck && npm run lint:ci && node scripts/verify-no-cloudflare.mjs && npm run build && node scripts/smoke-next.mjs",
    "check:rag": "node scripts/check-rag-index.mjs",
    "check:rag:local": "node scripts/check-rag-local.mjs",
    "check:rag:prod": "node scripts/check-rag-index.mjs https://www.agrinexuslaw.com",
    "check:documents": "node scripts/check-documents.mjs",
    "check:production": "npx tsx scripts/check-production-env.ts",
    "reindex": "node scripts/run-reindex.mjs",
    "reindex:direct": "npx tsx scripts/reindex-direct.ts",
    "reindex:static": "node scripts/run-reindex.mjs http://localhost:3002 static",
    "reindex:direct:static": "npx tsx scripts/reindex-direct.ts static",
    "reindex:prod": "node scripts/run-reindex.mjs https://www.agrinexuslaw.com",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:doctor": "npx cap doctor",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mcp": "npx tsx mcp-server/index.ts",
    "mcp:inspect": "npx @modelcontextprotocol/inspector npx tsx mcp-server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node scripts/run-migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx lib/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.3",
    "@vercel/analytics": "^1.4.1",
    "ai": "^6.0.189",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "duck-duck-scrape": "^2.2.7",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.9.1",
    "meilisearch": "^0.58.0",
    "next": "15.5.15",
    "openai": "^6.35.0",
    "pdf-to-img": "^4.5.0",
    "pdfjs-dist": "^4.10.38",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "resend": "^4.0.1",
    "shpjs": "^6.2.0",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^5.1.1",
    "typesense": "^2.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.15",
    "postcss": "8.5.10",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2"
  }
}
